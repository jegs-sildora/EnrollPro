generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// System users: registrars and system administrators who manage the enrollment process
model User {
  id                                   Int                            @id @default(autoincrement())
  firstName                            String                         @map("first_name")
  lastName                             String                         @map("last_name")
  middleName                           String?                        @map("middle_name")
  suffix                               String?
  sex                                  Sex                            @default(FEMALE)
  employeeId                           String?                        @unique(map: "uq_users_employee_id") @map("employee_id")
  designation                          String?
  mobileNumber                         String?                        @map("mobile_number")
  email                                String                         @unique(map: "uq_users_email")
  password                             String
  role                                 Role
  isActive                             Boolean                        @default(true) @map("is_active")
  lastLoginAt                          DateTime?                      @map("last_login_at") @db.Timestamptz(6)
  mustChangePassword                   Boolean                        @default(false) @map("must_change_password")
  createdById                          Int?                           @map("created_by_id")
  createdAt                            DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                            DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)
  accounts                             Account[]
  updatedChecklists                    ApplicationChecklist[]         @relation("ChecklistUpdatedBy")
  auditLogs                            AuditLog[]
  encodedEarlyRegs                     EarlyRegistrationApplication[] @relation("EarlyRegEncodedBy")
  verifiedEarlyRegs                    EarlyRegistrationApplication[] @relation("EarlyRegVerifiedBy")
  encodedEnrollmentApps                EnrollmentApplication[]        @relation("EnrollmentAppEncodedBy")
  profileLockedEnrollmentApps          EnrollmentApplication[]        @relation("EnrollmentProfileLockedBy")
  readingProfileAssessedEnrollmentApps EnrollmentApplication[]        @relation("EnrollmentReadingProfileAssessedBy")
  enrollmentRecords                    EnrollmentRecord[]
  recordedHealthRecords                HealthRecord[]                 @relation("HealthRecordRecordedBy")
  lockedSchoolYears                    SchoolYear[]                   @relation("SchoolYearLockedBy")
  updatedTeacherDesignations           TeacherDesignation[]           @relation("TeacherDesignationUpdatedBy")
  createdBy                            User?                          @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers                         User[]                         @relation("UserCreatedBy")

  @@map("users")
}

/// OAuth identities linked to invited users; modeled after Auth.js account linkage
model Account {
  id                Int      @id @default(autoincrement())
  userId            Int      @map("user_id")
  type              String   @default("oauth")
  provider          String
  providerAccountId String   @map("provider_account_id")
  refreshToken      String?  @map("refresh_token")
  accessToken       String?  @map("access_token")
  expiresAt         Int?     @map("expires_at")
  tokenType         String?  @map("token_type")
  scope             String?
  idToken           String?  @map("id_token")
  sessionState      String?  @map("session_state")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], map: "uq_accounts_provider_provider_account_id")
  @@index([userId], map: "idx_accounts_user_id")
  @@map("accounts")
}

/// Faculty members who serve as section advisers; not login users
model Teacher {
  id                  Int                  @id @default(autoincrement())
  employeeId          String               @unique(map: "uq_teachers_employee_id") @map("employee_id")
  firstName           String               @map("first_name")
  lastName            String               @map("last_name")
  middleName          String?              @map("middle_name")
  email               String               @unique(map: "uq_teachers_email") @map("email")
  contactNumber       String?              @map("contact_number")
  specialization      String?
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  photoPath           String?              @map("photo_path")
  plantillaPosition   String?              @map("plantilla_position")
  designation         String?
  departmentId        Int?                 @map("department_id")
  atlasSyncEvents     AtlasSyncEvent[]
  headedDepartment    Department?          @relation("DepartmentHead")
  advisoryHistory     SectionAdviser[]
  teacherDesignations TeacherDesignation[]
  subjects            TeacherSubject[]
  department          Department?          @relation("DepartmentTeachers", fields: [departmentId], references: [id])

  @@map("teachers")
}

/// Singleton config: school identity (name, logo, accent color) and active school year pointer
model SchoolSetting {
  id                 Int         @id @default(autoincrement())
  schoolName         String      @map("school_name")
  logoPath           String?     @map("logo_path")
  logoUrl            String?     @map("logo_url")
  colorScheme        Json?       @map("color_scheme")
  selectedAccentHsl  String?     @map("selected_accent_hsl")
  activeSchoolYearId Int?        @map("active_school_year_id")
  depedEmail         String?     @map("deped_email")
  facebookPageUrl    String?     @map("facebook_page_url")
  schoolWebsite      String?     @map("school_website")
  activeSchoolYear   SchoolYear? @relation(fields: [activeSchoolYearId], references: [id])

  @@map("school_settings")
}

/// Academic year with enrollment window dates and lifecycle status
model SchoolYear {
  id                            Int                            @id @default(autoincrement())
  yearLabel                     String                         @unique(map: "uq_school_years_year_label") @map("year_label")
  status                        SchoolYearStatus               @default(DRAFT)
  classOpeningDate              DateTime?                      @map("class_opening_date") @db.Date
  classEndDate                  DateTime?                      @map("class_end_date") @db.Date
  earlyRegOpenDate              DateTime?                      @map("early_reg_open_date") @db.Date
  earlyRegCloseDate             DateTime?                      @map("early_reg_close_date") @db.Date
  enrollOpenDate                DateTime?                      @map("enroll_open_date") @db.Date
  enrollCloseDate               DateTime?                      @map("enroll_close_date") @db.Date
  clonedFromId                  Int?                           @map("cloned_from_id")
  createdAt                     DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  isEosyFinalized               Boolean                        @default(false) @map("is_eosy_finalized")
  sectionShiftWindowDays        Int?                           @map("section_shift_window_days")
  sectioningConfig              Json?                          @map("sectioning_config")
  bosyLockedAt                  DateTime?                      @map("bosy_locked_at") @db.Timestamptz(6)
  bosyLockedById                Int?                           @map("bosy_locked_by_id")
  portalControl                 PortalControl                  @default(AUTO) @map("portal_control")
  atlasSyncEvents               AtlasSyncEvent[]
  earlyRegistrationApplications EarlyRegistrationApplication[]
  enrollmentApplications        EnrollmentApplication[]
  enrollmentRecords             EnrollmentRecord[]
  healthRecords                 HealthRecord[]
  schoolSettings                SchoolSetting[]
  bosyLockedBy                  User?                          @relation("SchoolYearLockedBy", fields: [bosyLockedById], references: [id])
  clonedFrom                    SchoolYear?                    @relation("SchoolYearClone", fields: [clonedFromId], references: [id])
  clones                        SchoolYear[]                   @relation("SchoolYearClone")
  scpProgramConfigs             ScpProgramConfig[]
  sectionAdvisers               SectionAdviser[]
  sections                      Section[]
  teacherDesignations           TeacherDesignation[]

  @@map("school_years")
}

/// JHS grade levels (e.g. Grade 7, Grade 10) - Permanent global records
model GradeLevel {
  id                            Int                            @id @default(autoincrement())
  name                          String                         @unique(map: "uq_grade_levels_name")
  displayOrder                  Int                            @map("display_order")
  createdAt                     DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  earlyRegistrationApplications EarlyRegistrationApplication[]
  enrollmentApplications        EnrollmentApplication[]
  sections                      Section[]

  @@map("grade_levels")
}

/// Class section with capacity, grade level, and optional advising teacher
model Section {
  id                  Int                  @id @default(autoincrement())
  name                String
  maxCapacity         Int                  @default(40) @map("max_capacity")
  gradeLevelId        Int                  @map("grade_level_id")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  programType         ApplicantType        @default(REGULAR) @map("program_type")
  isEosyFinalized     Boolean              @default(false) @map("is_eosy_finalized")
  displayName         String?              @map("display_name")
  sortOrder           Int                  @default(9999) @map("sort_order")
  isHomogeneous       Boolean              @default(false) @map("is_homogeneous")
  isSnake             Boolean              @default(false) @map("is_snake")
  schoolYearId        Int                  @map("school_year_id")
  enrollmentRecords   EnrollmentRecord[]
  advisers            SectionAdviser[]
  gradeLevel          GradeLevel           @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)
  schoolYear          SchoolYear           @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  teacherDesignations TeacherDesignation[] @relation("TeacherDesignationAdvisorySection")

  @@unique([name, gradeLevelId, schoolYearId], name: "uq_sections_name_grade_sy")
  @@index([gradeLevelId], map: "idx_sections_grade_level_id")
  @@index([schoolYearId], map: "idx_sections_school_year_id")
  @@index([gradeLevelId, programType], map: "idx_sections_grade_level_program_type")
  @@map("sections")
}

/// Historical ledger of section adviserships for DepEd audit compliance
model SectionAdviser {
  id             Int                  @id @default(autoincrement())
  sectionId      Int                  @map("section_id")
  teacherId      Int                  @map("teacher_id")
  schoolYearId   Int                  @map("school_year_id")
  effectiveFrom  DateTime             @map("effective_from") @db.Date
  effectiveTo    DateTime?            @map("effective_to") @db.Date
  status         SectionAdviserStatus @default(ACTIVE) @map("status")
  handoverReason String?              @map("handover_reason")
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  schoolYear     SchoolYear           @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  section        Section              @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacher        Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([sectionId], map: "idx_section_advisers_section_id")
  @@index([teacherId], map: "idx_section_advisers_teacher_id")
  @@map("section_advisers")
}

/// Core learner demographics shared between early registration and enrollment
model Learner {
  id                            Int                            @id @default(autoincrement())
  lrn                           String?                        @unique(map: "uq_learners_lrn") @db.VarChar(12)
  firstName                     String                         @map("first_name")
  lastName                      String                         @map("last_name")
  middleName                    String?                        @map("middle_name")
  extensionName                 String?                        @map("extension_name")
  birthdate                     DateTime                       @db.Date
  sex                           Sex
  placeOfBirth                  String?                        @map("place_of_birth")
  religion                      String?
  motherTongue                  String?                        @map("mother_tongue")
  isIpCommunity                 Boolean                        @default(false) @map("is_ip_community")
  ipGroupName                   String?                        @map("ip_group_name")
  isLearnerWithDisability       Boolean                        @default(false) @map("is_learner_with_disability")
  disabilityTypes               String[]                       @map("disability_types")
  is4PsBeneficiary              Boolean                        @default(false) @map("is_4ps_beneficiary")
  householdId4Ps                String?                        @map("household_id_4ps")
  createdAt                     DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)
  hasPwdId                      Boolean                        @default(false) @map("has_pwd_id")
  isBalikAral                   Boolean                        @default(false) @map("is_balik_aral")
  lastGradeLevel                String?                        @map("last_grade_level")
  lastYearEnrolled              String?                        @map("last_year_enrolled")
  psaBirthCertNumber            String?                        @map("psa_birth_cert_number")
  specialNeedsCategory          String?                        @map("special_needs_category")
  isPendingLrnCreation          Boolean                        @default(false) @map("is_pending_lrn_creation")
  externalId                    String                         @unique(map: "uq_learners_external_id") @default(dbgenerated("gen_random_uuid()")) @map("external_id") @db.Uuid
  studentPhoto                  String?                        @map("student_photo")
  snedPlacement                 String?                        @map("sned_placement")
  previousGenAve                Float?                         @map("previous_gen_ave")
  promotionStatus               String?                        @map("promotion_status")
  birthCertificateType          String?                        @map("birth_certificate_type")
  birthCertificateVerifiedBy    String?                        @map("birth_certificate_verified_by")
  birthCertificateVerifiedDate  DateTime?                      @map("birth_certificate_verified_date") @db.Timestamptz(6)
  hasPsaBirthCertificate        Boolean                        @default(false) @map("has_psa_birth_certificate")
  earlyRegistrationApplications EarlyRegistrationApplication[]
  enrollmentApplications        EnrollmentApplication[]
  healthRecords                 HealthRecord[]

  @@index([lastName, firstName, birthdate], map: "idx_learners_dedup")
  @@map("learners")
}

/// One registration record per learner per school year (Phase 1: Jan–May)
model EarlyRegistrationApplication {
  id                         Int                           @id @default(autoincrement())
  learnerId                  Int                           @map("learner_id")
  schoolYearId               Int                           @map("school_year_id")
  gradeLevelId               Int                           @map("grade_level_id")
  trackingNumber             String                        @unique(map: "uq_early_reg_tracking_number") @map("tracking_number")
  applicantType              ApplicantType                 @default(REGULAR) @map("applicant_type")
  learnerType                LearnerType                   @default(NEW_ENROLLEE) @map("learner_type")
  status                     ApplicationStatus             @default(SUBMITTED_BEERF)
  channel                    AdmissionChannel              @default(ONLINE)
  contactNumber              String                        @map("contact_number")
  email                      String?
  primaryContact             PrimaryContactType?           @map("primary_contact")
  isPrivacyConsentGiven      Boolean                       @map("is_privacy_consent_given")
  encodedById                Int?                          @map("encoded_by_id")
  verifiedAt                 DateTime?                     @map("verified_at") @db.Timestamptz(6)
  verifiedById               Int?                          @map("verified_by_id")
  submittedAt                DateTime                      @default(now()) @map("submitted_at") @db.Timestamptz(6)
  createdAt                  DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  guardianRelationship       String?                       @map("guardian_relationship")
  hasNoFather                Boolean                       @default(false) @map("has_no_father")
  hasNoMother                Boolean                       @default(false) @map("has_no_mother")
  reportedGrades             Json?                         @map("reported_grades")
  hasSf9CertificationLetter  Boolean                       @default(false) @map("has_sf9_certification_letter")
  hasUnsettledPrivateAccount Boolean                       @default(false) @map("has_unsettled_private_account")
  isMissingSf9               Boolean                       @default(false) @map("is_missing_sf9")
  originatingSchoolName      String?                       @map("originating_school_name")
  addresses                  ApplicationAddress[]
  checklist                  ApplicationChecklist?
  familyMembers              ApplicationFamilyMember[]
  encodedBy                  User?                         @relation("EarlyRegEncodedBy", fields: [encodedById], references: [id])
  gradeLevel                 GradeLevel                    @relation(fields: [gradeLevelId], references: [id])
  learner                    Learner                       @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  schoolYear                 SchoolYear                    @relation(fields: [schoolYearId], references: [id])
  verifiedBy                 User?                         @relation("EarlyRegVerifiedBy", fields: [verifiedById], references: [id])
  assessments                EarlyRegistrationAssessment[]
  enrollmentApplications     EnrollmentApplication[]

  @@unique([learnerId, schoolYearId], name: "uq_early_reg_per_sy")
  @@index([schoolYearId, status], map: "idx_early_reg_sy_status")
  @@index([trackingNumber], map: "idx_early_reg_tracking_no")
  @@map("early_registration_applications")
}

/// Screening assessments taken during early registration (e.g., STE Qualifying Exam)
model EarlyRegistrationAssessment {
  id            Int                          @id @default(autoincrement())
  applicationId Int                          @map("application_id")
  type          AssessmentKind               @map("assessment_kind")
  scheduledDate DateTime?                    @map("scheduled_date") @db.Date
  scheduledTime String?                      @map("scheduled_time")
  venue         String?
  score         Float?
  result        String?
  notes         String?
  conductedAt   DateTime?                    @map("conducted_at") @db.Timestamptz(6)
  createdAt     DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  application   EarlyRegistrationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId], map: "idx_early_reg_assessments_app_id")
  @@map("early_registration_assessments")
}

/// The Basic Education Enrollment Form record
model EnrollmentApplication {
  id                         Int                           @id @default(autoincrement())
  learnerId                  Int                           @map("learner_id")
  earlyRegistrationId        Int?                          @map("early_registration_id")
  schoolYearId               Int                           @map("school_year_id")
  gradeLevelId               Int                           @map("grade_level_id")
  applicantType              ApplicantType                 @default(REGULAR) @map("applicant_type")
  learnerType                LearnerType                   @default(NEW_ENROLLEE) @map("learner_type")
  status                     ApplicationStatus             @default(SUBMITTED_BEEF)
  admissionChannel           AdmissionChannel              @default(ONLINE) @map("admission_channel")
  trackingNumber             String?                       @unique(map: "uq_enrollment_tracking_number") @map("tracking_number")
  learningModalities         String[]                      @map("learning_modalities")
  isTemporarilyEnrolled      Boolean                       @default(false) @map("is_temporarily_enrolled")
  documentaryDeadlineAt      DateTime?                     @map("documentary_deadline_at") @db.Date
  complianceStatus           ComplianceStatus?             @map("compliance_status")
  rejectionReason            String?                       @map("rejection_reason")
  isPrivacyConsentGiven      Boolean                       @default(false) @map("is_privacy_consent_given")
  portalPin                  String?                       @map("portal_pin")
  portalPinChangedAt         DateTime?                     @map("portal_pin_changed_at") @db.Timestamptz(6)
  encodedById                Int?                          @map("encoded_by_id")
  createdAt                  DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  guardianRelationship       String?                       @map("guardian_relationship")
  hasNoFather                Boolean                       @default(false) @map("has_no_father")
  hasNoMother                Boolean                       @default(false) @map("has_no_mother")
  isProfileLocked            Boolean                       @default(false) @map("is_profile_locked")
  profileLockedAt            DateTime?                     @map("profile_locked_at") @db.Timestamptz(6)
  profileLockedById          Int?                          @map("profile_locked_by_id")
  readingProfileLevel        ReadingProfileLevel?          @map("reading_profile_level")
  readingProfileNotes        String?                       @map("reading_profile_notes")
  readingProfileAssessedAt   DateTime?                     @map("reading_profile_assessed_at") @db.Timestamptz(6)
  readingProfileAssessedById Int?                          @map("reading_profile_assessed_by_id")
  batchIntakeMethod          String?                       @map("batch_intake_method")
  confirmationConsent        Boolean?                      @map("confirmation_consent")
  contactNumber              String?                       @map("contact_number")
  guardianName               String?                       @map("guardian_name")
  hasSf9CertificationLetter  Boolean                       @default(false) @map("has_sf9_certification_letter")
  hasUnsettledPrivateAccount Boolean                       @default(false) @map("has_unsettled_private_account")
  intakeMethod               IntakeMethod                  @default(BEEF_FULL) @map("intake_method")
  isMissingSf9               Boolean                       @default(false) @map("is_missing_sf9")
  originatingSchoolName      String?                       @map("originating_school_name")
  temporaryStatusDeadline    DateTime?                     @map("temporary_status_deadline") @db.Date
  addresses                  ApplicationAddress[]
  checklist                  ApplicationChecklist?
  familyMembers              ApplicationFamilyMember[]
  earlyRegistration          EarlyRegistrationApplication? @relation(fields: [earlyRegistrationId], references: [id])
  encodedBy                  User?                         @relation("EnrollmentAppEncodedBy", fields: [encodedById], references: [id])
  gradeLevel                 GradeLevel                    @relation(fields: [gradeLevelId], references: [id])
  learner                    Learner                       @relation(fields: [learnerId], references: [id])
  profileLockedBy            User?                         @relation("EnrollmentProfileLockedBy", fields: [profileLockedById], references: [id])
  readingProfileAssessedBy   User?                         @relation("EnrollmentReadingProfileAssessedBy", fields: [readingProfileAssessedById], references: [id])
  schoolYear                 SchoolYear                    @relation(fields: [schoolYearId], references: [id])
  previousSchool             EnrollmentPreviousSchool?
  programDetail              EnrollmentProgramDetail?
  enrollmentRecord           EnrollmentRecord?

  @@index([status, schoolYearId], map: "idx_enrollment_apps_status_sy")
  @@map("enrollment_applications")
}

/// Previous school record linked to enrollment application
model EnrollmentPreviousSchool {
  id                 Int                   @id @default(autoincrement())
  applicationId      Int                   @unique(map: "uq_enrollment_prev_school_app_id") @map("application_id")
  schoolName         String?               @map("school_name")
  schoolDepedId      String?               @map("school_deped_id")
  gradeCompleted     String?               @map("grade_completed")
  schoolYearAttended String?               @map("school_year_attended")
  schoolAddress      String?               @map("school_address")
  schoolType         String?               @map("school_type")
  natScore           Float?                @map("nat_score")
  generalAverage     Float?                @map("general_average")
  application        EnrollmentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("enrollment_previous_schools")
}

/// SCP-specific details for enrollment applications
model EnrollmentProgramDetail {
  id              Int                   @id @default(autoincrement())
  applicationId   Int                   @unique(map: "uq_enrollment_prog_detail_app_id") @map("application_id")
  scpType         ApplicantType         @map("scp_type")
  artField        String?               @map("art_field")
  foreignLanguage String?               @map("foreign_language")
  sportsList      String[]              @map("sports_list")
  application     EnrollmentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("enrollment_program_details")
}

/// Address linked to an application (Early Reg or Enrollment)
model ApplicationAddress {
  id                  Int                           @id @default(autoincrement())
  earlyRegistrationId Int?                          @map("early_registration_id")
  enrollmentId        Int?                          @map("enrollment_id")
  addressType         AddressType                   @map("address_type")
  houseNoStreet       String?                       @map("house_no")
  street              String?
  sitio               String?
  barangay            String?
  cityMunicipality    String?                       @map("city_municipality")
  province            String?
  country             String?                       @default("PHILIPPINES")
  zipCode             String?                       @map("zip_code")
  earlyRegistration   EarlyRegistrationApplication? @relation(fields: [earlyRegistrationId], references: [id], onDelete: Cascade)
  enrollment          EnrollmentApplication?        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([earlyRegistrationId, addressType], name: "uq_early_reg_addresses_type")
  @@unique([enrollmentId, addressType], name: "uq_enrollment_addresses_type")
  @@map("application_addresses")
}

/// Parent or guardian info linked to an application
model ApplicationFamilyMember {
  id                  Int                           @id @default(autoincrement())
  earlyRegistrationId Int?                          @map("early_registration_id")
  enrollmentId        Int?                          @map("enrollment_id")
  relationship        FamilyRelationship
  firstName           String                        @map("first_name")
  lastName            String                        @map("last_name")
  middleName          String?                       @map("middle_name")
  contactNumber       String?                       @map("contact_number")
  email               String?
  occupation          String?
  maidenName          String?                       @map("maiden_name")
  earlyRegistration   EarlyRegistrationApplication? @relation(fields: [earlyRegistrationId], references: [id], onDelete: Cascade)
  enrollment          EnrollmentApplication?        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, relationship], name: "uq_enrollment_family_members_rel")
  @@index([earlyRegistrationId], map: "idx_early_reg_guardians_app_id")
  @@map("application_family_members")
}

/// Requirement checklist per application
model ApplicationChecklist {
  id                           Int                           @id @default(autoincrement())
  earlyRegistrationId          Int?                          @unique(map: "uq_early_reg_checklist_id") @map("early_registration_id")
  enrollmentId                 Int?                          @unique(map: "uq_enrollment_checklist_id") @map("enrollment_id")
  isPsaBirthCertPresented      Boolean                       @default(false) @map("is_psa_birth_cert_presented")
  isOriginalPsaBcCollected     Boolean                       @default(false) @map("is_original_psa_bc_collected")
  isSf9Submitted               Boolean                       @default(false) @map("is_sf9_submitted")
  isSf10Requested              Boolean                       @default(false) @map("is_sf10_requested")
  isGoodMoralPresented         Boolean                       @default(false) @map("is_good_moral_presented")
  isMedicalEvalSubmitted       Boolean                       @default(false) @map("is_medical_eval_submitted")
