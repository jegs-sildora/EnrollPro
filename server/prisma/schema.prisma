/// Historical ledger of end-of-school-year data
model EnrollmentHistory {
  id             Int         @id @default(autoincrement())
  learnerId      Int         @map("learner_id")
  schoolYearId   Int         @map("school_year_id")
  gradeLevelId   Int         @map("grade_level_id")
  sectionId      Int?        @map("section_id")
  adviserId      Int?        @map("adviser_id")
  genAve         Float?      @map("gen_ave")
  eosyStatus     EosyStatus? @map("eosy_status")
  academicDeficiencyNote String? @map("academic_deficiency_note")
  learnerProfileSnapshot Json? @map("learner_profile_snapshot")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  learner        Learner     @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  schoolYear     SchoolYear  @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  gradeLevel     GradeLevel  @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)
  section        Section?    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  adviser        Teacher?    @relation(fields: [adviserId], references: [id], onDelete: Cascade)

  @@index([learnerId, schoolYearId], map: "idx_enrollment_history_learner_sy")
  @@map("enrollment_history")
}


