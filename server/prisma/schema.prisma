/// School-year scoped ATLAS designation metadata for faculty load computation
model TeacherDesignation {
  id                               Int        @id @default(autoincrement())
  teacherId                        Int        @map("teacher_id")
  schoolYearId                     Int        @map("school_year_id")
  isClassAdviser                   Boolean    @default(false) @map("is_class_adviser")
  advisoryEquivalentHoursPerWeek   Float      @default(0) @map("advisory_equivalent_hours_per_week")
  isTeachingExempt                 Boolean    @default(false) @map("is_teaching_exempt")
  customTargetTeachingHoursPerWeek Float?     @map("custom_target_teaching_hours_per_week")
  designationNotes                 String?    @map("designation_notes")
  effectiveFrom                    DateTime?  @map("effective_from") @db.Date
  effectiveTo                      DateTime?  @map("effective_to") @db.Date
  updateReason                     String?    @map("update_reason")
  updatedById                      Int?       @map("updated_by_id")
  createdAt                        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  advisorySectionId                Int?       @map("advisory_section_id")
  ancillaryRoles                   String[]   @default([]) @map("ancillary_roles")
  advisorySection                  Section?   @relation("TeacherDesignationAdvisorySection", fields: [advisorySectionId], references: [id])
  schoolYear                       SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  teacher                          Teacher    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  updatedBy                        User?      @relation("TeacherDesignationUpdatedBy", fields: [updatedById], references: [id])

  @@unique([teacherId, schoolYearId], name: "uq_teacher_designations_teacher_sy")
  @@index([schoolYearId], map: "idx_teacher_designations_school_year_id")
  @@index([advisorySectionId], map: "idx_teacher_designations_advisory_section_id")
  @@index([updatedById], map: "idx_teacher_designations_updated_by_id")
  @@map("teacher_designations")
}

/// Outbound EnrollPro -> ATLAS synchronization events for observability and retries
model AtlasSyncEvent {
  id             Int             @id @default(autoincrement())
  eventId        String          @unique(map: "uq_atlas_sync_events_event_id") @map("event_id")
  eventType      String          @map("event_type")
  teacherId      Int?            @map("teacher_id")
  schoolYearId   Int?            @map("school_year_id")
  payload        Json
  requestUrl     String          @map("request_url")
  status         AtlasSyncStatus @default(PENDING)
  httpStatus     Int?            @map("http_status")
  responseBody   Json?           @map("response_body")
  errorMessage   String?         @map("error_message")
  attemptCount   Int             @default(0) @map("attempt_count")
  maxAttempts    Int             @default(5) @map("max_attempts")
  durationMs     Int?            @map("duration_ms")
  lastAttemptAt  DateTime?       @map("last_attempt_at") @db.Timestamptz(6)
  nextRetryAt    DateTime?       @map("next_retry_at") @db.Timestamptz(6)
  acknowledgedAt DateTime?       @map("acknowledged_at") @db.Timestamptz(6)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  schoolYear     SchoolYear?     @relation(fields: [schoolYearId], references: [id])
  teacher        Teacher?        @relation(fields: [teacherId], references: [id])

  @@index([status, nextRetryAt], map: "idx_atlas_sync_events_status_retry")
  @@index([teacherId, createdAt], map: "idx_atlas_sync_events_teacher_created_at")
  @@index([schoolYearId, createdAt], map: "idx_atlas_sync_events_sy_created_at")
  @@index([createdAt], map: "idx_atlas_sync_events_created_at")
  @@map("atlas_sync_events")
}

