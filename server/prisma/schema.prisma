  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  headId      Int?      @unique(map: "uq_departments_head_id") @map("head_id")
  head        Teacher?  @relation("DepartmentHead", fields: [headId], references: [id])
  teachers    Teacher[] @relation("DepartmentTeachers")

  @@map("departments")
}

/// Immutable audit trail of all system actions
model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  actionType  String   @map("action_type")
  description String
  subjectType String?  @map("subject_type")
  recordId    Int?     @map("record_id")
  ipAddress   String   @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User?    @relation(fields: [userId], references: [id])

  @@index([actionType], map: "idx_audit_logs_action_type")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@index([userId], map: "idx_audit_logs_user_id")
  @@map("audit_logs")
}

/// Student health measurement (SF8)
model HealthRecord {
  id               Int              @id @default(autoincrement())
  learnerId        Int              @map("learner_id")
  schoolYearId     Int              @map("school_year_id")
  assessmentPeriod AssessmentPeriod @map("assessment_period")
  assessmentDate   DateTime         @map("assessment_date") @db.Date
  weightKg         Float            @map("weight_kg")
  heightCm         Float            @map("height_cm")
  notes            String?
  recordedById     Int              @map("recorded_by_id")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  learner          Learner          @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  recordedBy       User             @relation("HealthRecordRecordedBy", fields: [recordedById], references: [id])
  schoolYear       SchoolYear       @relation(fields: [schoolYearId], references: [id])

  @@unique([learnerId, schoolYearId, assessmentPeriod], name: "uq_health_records_period")
  @@index([learnerId], map: "idx_health_records_learner_id")
  @@map("health_records")
}

/// Special Curricular Program configuration
model ScpProgramConfig {
  id                Int                @id @default(autoincrement())
  schoolYearId      Int                @map("school_year_id")
  scpType           ApplicantType      @map("scp_type")
  isOffered         Boolean            @default(false) @map("is_offered")
  isTwoPhase        Boolean            @default(false) @map("is_two_phase")
  cutoffScore       Float?             @map("cutoff_score")
  gradeRequirements Json?              @map("grade_requirements")
  rankingFormula    Json?              @map("ranking_formula")
  notes             String?
  schoolYear        SchoolYear         @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  options           ScpProgramOption[]
  steps             ScpProgramStep[]

  @@unique([schoolYearId, scpType], name: "uq_scp_program_configs_type")
  @@map("scp_program_configs")
}

/// Ordered assessment step in an SCP admission pipeline
model ScpProgramStep {
  id                 Int                          @id @default(autoincrement())
  scpProgramConfigId Int                          @map("scp_program_config_id")
  stepOrder          Int                          @map("step_order")
  kind               AssessmentKind               @map("assessment_kind")
  label              String
  description        String?
  isRequired         Boolean                      @default(true) @map("is_required")
  scheduledDate      DateTime?                    @map("scheduled_date") @db.Date
  scheduledTime      String?                      @map("scheduled_time")
  venue              String?
  notes              String?
  cutoffScore        Float?                       @map("cutoff_score")
  rubric             Json?
  rubricCategories   ScpInterviewRubricCategory[]
  scpProgramConfig   ScpProgramConfig             @relation(fields: [scpProgramConfigId], references: [id], onDelete: Cascade)

  @@unique([scpProgramConfigId, stepOrder], name: "uq_scp_program_steps_order")
  @@index([scpProgramConfigId], map: "idx_scp_program_steps_config_id")
  @@map("scp_program_steps")
}

/// Dynamic rubric categories for an assessment step
model ScpInterviewRubricCategory {
  id               Int                           @id @default(autoincrement())
  scpProgramStepId Int                           @map("scp_program_step_id")
  name             String
  displayOrder     Int                           @default(0) @map("display_order")
  scpProgramStep   ScpProgramStep                @relation(fields: [scpProgramStepId], references: [id], onDelete: Cascade)
  criteria         ScpInterviewRubricCriterion[]

  @@index([scpProgramStepId], map: "idx_rubric_categories_step_id")
  @@map("scp_interview_rubric_categories")
}

/// Individual scoring criteria within a rubric category
model ScpInterviewRubricCriterion {
  id               Int                        @id @default(autoincrement())
  rubricCategoryId Int                        @map("rubric_category_id")
  name             String
  description      String?
  maxPts           Float                      @map("max_pts")
  displayOrder     Int                        @default(0) @map("display_order")
  category         ScpInterviewRubricCategory @relation(fields: [rubricCategoryId], references: [id], onDelete: Cascade)

  @@index([rubricCategoryId], map: "idx_rubric_criteria_category_id")
  @@map("scp_interview_rubric_criteria")
}

/// Options for SCP configuration
model ScpProgramOption {
  id                 Int              @id @default(autoincrement())
  scpProgramConfigId Int              @map("scp_program_config_id")
  optionType         ScpOptionType    @map("option_type")
  value              String
  scpProgramConfig   ScpProgramConfig @relation(fields: [scpProgramConfigId], references: [id], onDelete: Cascade)

  @@unique([scpProgramConfigId, optionType, value], name: "uq_scp_program_options_value")
  @@index([scpProgramConfigId], map: "idx_scp_program_options_config_id")
  @@map("scp_program_options")
}

/// Teacher subject specializations
